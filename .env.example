# Токен бота от @BotFather
BOT_TOKEN=1234567890:AAAA-your-telegram-bot-token

# Ключ OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# Модель через OpenRouter (формат provider/model)
LLM_MODEL=deepseek/deepseek-v4-flash

# Базовый URL OpenRouter (менять не нужно)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Путь к файлу базы знаний (YAML)
KNOWLEDGE_BASE_PATH=data/knowledge_base.yaml
